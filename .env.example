# Configuracao geral
NODE_ENV=development or production
PORT=3000
API_KEYS="api-key-1,api-key-2,api-key-3"
CRUD_API_KEY="crud-fixed-admin-key"

# Configuracao do banco de dados
DATABASE_URL="postgresql://postgres.ntxeyohsqdywzytfzqmx:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres"
DRIZZLE_DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Configuracao da API da Meta
META_API_BASE_URL=https://graph.facebook.com/v25.0 
META_PHONE_NUMBER_ID="meta-phone-number-id" # fallback temporario para mensagens
META_ACCESS_TOKEN="meta-access-token"

# Configuracao do Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=
AUDIT_ENABLED="true"
AUDIT_REDIS_PREFIX="audit"
AUDIT_RETENTION_DAYS="30"
AUDIT_CLEANUP_INTERVAL_MS="60000"

#Redis Cloud - Utilize o Redis Cloud para producao
REDIS_URL="rediss://default:<your-redis-cloud-password>@<your-redis-cloud-url>:6379"

# Configuracao da API
QUEUE_PREFIX=gescom_wpp_service_example
LOCAL_QUEUE_PREFIX=gescom_wpp_service_example_local
QUEUE_DRIVER=redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
REQUEST_TIMEOUT_MS=10000
IDEMPOTENCY_TTL_MS=600000
IDEMPOTENCY_CLEANUP_INTERVAL_MS=60000
QUEUE_MAX_ATTEMPTS=3
DEAD_LETTER_RETENTION_MS=86400000
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"