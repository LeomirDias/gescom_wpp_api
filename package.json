{
  "name": "gescom_wpp_service",
  "version": "1.0.0",
  "description": "Whatsapp Service API for Gescom Sys",
  "license": "ISC",
  "author": "LeomirDias",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --require ts-node/register --test \"src/**/*.test.ts\"",
    "test:integration": "node --require ts-node/register --test \"src/**/*.integration.test.ts\"",
    "load:burst": "node --require ts-node/register scripts/load/burst-mensagens-texto.js",
    "load:burst:documento": "node --require ts-node/register scripts/load/burst-mensagens-documento.js",
    "validate:technical": "npm run test:integration && npm run load:burst && npm run load:burst:documento",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.15.1",
    "bullmq": "^5.75.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
